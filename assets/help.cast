[0.002, "o", "\u001b[2mв•­в”Ђ\u001b[0m\u001b[2m Commands \u001b[0m\u001b[2mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\u001b[0m\u001b[2mв”Ђв•®\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36mdiscover  \u001b[0m\u001b[1;36m \u001b[0m Discover API endpoints for a website by capturing network        \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m           \u001b[0m traffic.                                                         \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36mrun       \u001b[0m\u001b[1;36m \u001b[0m Execute a discovered action on a site.                           \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36msetup     \u001b[0m\u001b[1;36m \u001b[0m Set up site2cli: install browsers, validate dependencies, create \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m           \u001b[0m directories.                                                     \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36minit      \u001b[0m\u001b[1;36m \u001b[0m Generate agent configuration for discovered sites.               \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36mversion   \u001b[0m\u001b[1;36m \u001b[0m Sh"]
[0.000, "o", "ow site2cli version.                                           \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36msites     \u001b[0m\u001b[1;36m \u001b[0m Manage discovered sites                                          \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36mauth      \u001b[0m\u001b[1;36m \u001b[0m Manage authentication                                            \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36mcookies   \u001b[0m\u001b[1;36m \u001b[0m Cookie management                                                \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36msession   \u001b[0m\u001b[1;36m \u001b[0m Browser session management                                       \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36mworkflows \u001b[0m\u001b[1;36m \u001b[0m Manage recorded workflows                                        \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36mmcp       \u001b[0m\u001b[1;36m \u001b[0m MCP server management                                            \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36mhealth    \u001b[0m\u001b[1;36m \u001b[0m API health monitoring                                            \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36mcommunity \u001b[0m\u001b[1;36m \u001b[0m Community spec sharing            "]
